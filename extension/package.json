{
  "name": "ai-context-layer",
  "displayName": "OmniContext.ai",
  "version": "0.1.0",
  "description": "AI developer assistant for GitHub and Stack Overflow",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "highlight.js": "^11.10.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.1",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "^3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "storage",
      "tabs",
      "sidePanel",
      "scripting"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "commands": {
      "_execute_side_panel": {
        "suggested_key": {
          "default": "Ctrl+Shift+A"
        },
        "description": "Toggle AI Context Layer"
      }
    }
  }
}
